<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Admin - Cookie Control</title>
</head>
<body>
    <h1>Управление статистикой</h1>
    <button onclick="enableDebug()">Включить режим разработчика (Блокировать GTM/Pixel)</button>
    <button onclick="disableDebug()">Выключить режим разработчика (Разрешить отправку)</button>

    <p>Текущий статус: <strong id="status">проверка...</strong></p>

    <script>
        function updateStatus() {
            const isDebug = localStorage.getItem('no_analytics') === 'true';
            document.getElementById('status').innerText = isDebug ? 'ЗАБЛОКИРОВАНО' : 'РАБОТАЕТ';
            document.getElementById('status').style.color = isDebug ? 'red' : 'green';
        }

        function enableDebug() {
            localStorage.setItem('no_analytics', 'true');
            updateStatus();

        }

        function disableDebug() {
            localStorage.removeItem('no_analytics');
            updateStatus();

        }

        updateStatus();
    </script>
</body>
</html>
